build/
build-*/
cmake-build-*/
out/
Debug/
Release/
RelWithDebInfo/
MinSizeRel/
x64/

# -----------------------------------------------------------------------------
# Qt Creator — ustawienia użytkownika i cache (nie wersjonuj)
# -----------------------------------------------------------------------------
*.user
*.user.*

# -----------------------------------------------------------------------------
# Wygenerowane przez CMake / Qt (gdy ktoś buduje w drzewie źródeł)
# -----------------------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
install_manifest.txt
CTestTestfile.cmake
_deps/
*.dir/

