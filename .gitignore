# -----------------------------------------------------------------------------
.vs/
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.suo
*.userosscache
*.tlog
*.obj
*.pch
*.pdb
*.ilk
*.exp
*.lib
*.dll
*.exe
*.idb
*.ipdb
*.iobj

# -----------------------------------------------------------------------------
# Qt — metadane kompilacji (na wypadek lokalnych śmieci poza build/)
# -----------------------------------------------------------------------------
*.moc
moc_*.cpp
qrc_*.cpp
ui_*.h
*.qm

# -----------------------------------------------------------------------------
# Edytory / OS
